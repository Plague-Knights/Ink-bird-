generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// One row per attempt consumed. `seed` is issued by the server when the
// client calls /api/attempts/start; the client plays with that seed and
// submits {inputs[], claimedScore}. On /api/replay/submit, the server
// re-simulates and writes the final `score` here. Unsubmitted rows
// (score=null) are counted as consumed — no double-spending the attempt.
model Attempt {
  id            String   @id @default(cuid())
  address       String
  weekId        Int
  seed          String   // hex, 16 chars = 64 bits
  inputs        Json?    // array of { f: frame, t: 'flap' }
  claimedScore  Int?
  score         Int?     // server-computed after replay
  valid         Boolean?
  createdAt     DateTime @default(now())
  submittedAt   DateTime?

  @@index([address, weekId])
  @@index([weekId, score(sort: Desc)])
}

// Weekly settlement record. Written when /api/admin/settle runs, before the
// settleWeek() tx is sent. Stores per-address payouts + merkle proofs so
// /api/claim-proof can serve them without recomputing.
model Settlement {
  weekId        Int      @id
  root          String   // 0x-prefixed bytes32
  totalPayout   String   // wei as string
  settledAt     DateTime @default(now())
  txHash        String?
  claims        ClaimProof[]
}

model ClaimProof {
  id            String   @id @default(cuid())
  weekId        Int
  address       String
  amount        String   // wei as string
  proof         Json     // array of 0x-prefixed bytes32
  settlement    Settlement @relation(fields: [weekId], references: [weekId], onDelete: Cascade)

  @@unique([weekId, address])
  @@index([address])
}

// Off-chain referral binding. Written on SIWE sign-in when the session
// carries a pendingReferrer captured from a `?ref=0x…` landing URL.
// One-time lock: `referred` is unique, so the first referrer wins
// forever and later visits with a different ref are ignored.
model Referral {
  id            String   @id @default(cuid())
  referrer      String   // lowercased 0x… wallet
  referred      String   @unique  // lowercased 0x… wallet
  createdAt     DateTime @default(now())

  @@index([referrer])
}

// Prototype "Squid Dive" gambling mode. Commit-reveal is fully off-chain
// for now: the server generates a secret seed, publishes keccak256(seed)
// when the round opens, and reveals the raw seed on settle. The outcome
// index is keccak256(seed || userSalt) mod datasetSize. Everything needed
// to verify is stored on the row so /api/dive/verify can prove fairness.
model DiveRound {
  id            String    @id @default(cuid())
  address       String    // lowercased 0x… wallet of the player
  tier          String    // "low" | "mid" | "high"
  betWei        String    // wei as string; charged from DiveBalance on open
  userSalt      String    // 0x… hex from the client, bound before reveal
  seedHash      String    // keccak256 of the server seed, committed on open
  seed          String?   // raw server seed, null until settle
  outcomeIndex  Int?      // keccak256(seed || salt) mod N, null until settle
  distance      Int?      // chosen from tier dataset[outcomeIndex]
  payoutWei     String?   // wei as string, null until settle
  createdAt     DateTime  @default(now())
  settledAt     DateTime?

  @@index([address, createdAt])
}

// Mock wei balance for the prototype. Funded via /api/dive/faucet during
// testing; no real ETH changes hands. When we wire the on-chain contract,
// this table goes away and the contract's internal ledger becomes truth.
model DiveBalance {
  address       String   @id  // lowercased 0x…
  wei           String   @default("0") // wei as string
  updatedAt     DateTime @updatedAt
}

// "Squid Launch" skill-bet mode. Reuses the main flappy game (simulate.ts
// + Game.tsx) verbatim — the player bets, a cannon intro plays, then
// it's the regular skill loop. The numeric sim seed is derived
// deterministically from keccak256(seed || salt) so the obstacle set
// the player faces is pinned at commit time; distance achieved is pure
// skill on top of that fixed map. Server re-runs simulate.replay() to
// validate inputs and compute the paid distance.
model LaunchRound {
  id            String    @id @default(cuid())
  address       String
  betWei        String
  userSalt      String
  seedHash      String
  seed          String?
  simSeed       BigInt?   // uint32 sim seed derived from keccak256(seed||salt)
  score         Int?      // validated pipes-passed from replay
  framesRun     Int?
  payoutWei     String?
  createdAt     DateTime  @default(now())
  settledAt     DateTime?

  @@index([address, createdAt])
}

// "Squid Chests" auto-flapper RNG game. Settled ON-CHAIN via the
// InkSquidChests contract; this row mirrors the round for UX (status
// polling, animation hand-off) and for keeping the seed pre-image
// off-chain until reveal.
//
// Lifecycle:
//   1. POST /api/chest/open → server stores { seedHash, seed (private) }
//   2. Player calls contract.play(seedHash) via wagmi
//   3. ChestWatcher sees Played event → fills contractRoundId/weekId/betWei/playedAt,
//      then signs reveal(roundId, seed) using the resolver key
//   4. ChestWatcher sees Resolved event → fills payoutWei/chestsHit/chestsTotal/died/settledAt
//   5. Frontend polls /api/chest/byHash/:hash and animates from the resolved data
model ChestRound {
  id              String    @id @default(cuid())
  address         String?
  seedHash        String    @unique
  seed            String
  contractRoundId Int?
  weekId          Int?
  betWei          String?
  payoutWei       String?
  chestsHit       Int?
  chestsTotal     Int?
  died            Boolean?
  txPlay          String?
  txReveal        String?
  createdAt       DateTime  @default(now())
  playedAt        DateTime?
  settledAt       DateTime?

  @@index([address, createdAt])
  @@index([contractRoundId])
  @@index([settledAt])
}

// Cursor table — single row tracking the highest block the chest
// watcher has scanned, so it doesn't re-walk history every tick.
model ChestWatcherCursor {
  id        Int    @id @default(1)
  lastBlock String // BigInt as decimal string for Postgres compatibility
}

// "Squid Cannon" launcher mode. Same commit-reveal cycle as DiveRound:
// the server pre-commits keccak256(seed) via /api/cannon/open, the
// player sends a salt with their bet to /api/cannon/play, the server
// reveals the seed and the outcome is a deterministic event sequence
// (ink blots hit + hazard terminator) keyed by
// uint32(keccak256(seed || salt)) mod datasetSize. totalMultiplierBps
// is the sum of the blot values in bps (10000 = 1x bet), saved so the
// client animation can replay it without recomputing.
model CannonRound {
  id                  String    @id @default(cuid())
  address             String    // lowercased 0x… wallet
  betWei              String    // wei as string, charged from DiveBalance on open
  userSalt            String    // 0x… hex from the client
  seedHash            String    // keccak256 of the server seed
  seed                String?   // raw seed, null until settle
  outcomeIndex        Int?      // dataset index, null until settle
  eventSeq            Json?     // array of { kind: 'blot' | 'hazard', value?: number }
  totalMultiplierBps  Int?      // sum of blot values in bps (100 = 0.01x)
  payoutWei           String?   // wei as string
  createdAt           DateTime  @default(now())
  settledAt           DateTime?

  @@index([address, createdAt])
}
