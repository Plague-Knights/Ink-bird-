generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// One row per attempt consumed. `seed` is issued by the server when the
// client calls /api/attempts/start; the client plays with that seed and
// submits {inputs[], claimedScore}. On /api/replay/submit, the server
// re-simulates and writes the final `score` here. Unsubmitted rows
// (score=null) are counted as consumed — no double-spending the attempt.
model Attempt {
  id            String   @id @default(cuid())
  address       String
  weekId        Int
  seed          String   // hex, 16 chars = 64 bits
  inputs        Json?    // array of { f: frame, t: 'flap' }
  claimedScore  Int?
  score         Int?     // server-computed after replay
  valid         Boolean?
  createdAt     DateTime @default(now())
  submittedAt   DateTime?

  @@index([address, weekId])
  @@index([weekId, score(sort: Desc)])
}

// Weekly settlement record. Written when /api/admin/settle runs, before the
// settleWeek() tx is sent. Stores per-address payouts + merkle proofs so
// /api/claim-proof can serve them without recomputing.
model Settlement {
  weekId        Int      @id
  root          String   // 0x-prefixed bytes32
  totalPayout   String   // wei as string
  settledAt     DateTime @default(now())
  txHash        String?
  claims        ClaimProof[]
}

model ClaimProof {
  id            String   @id @default(cuid())
  weekId        Int
  address       String
  amount        String   // wei as string
  proof         Json     // array of 0x-prefixed bytes32
  settlement    Settlement @relation(fields: [weekId], references: [weekId], onDelete: Cascade)

  @@unique([weekId, address])
  @@index([address])
}

// Off-chain referral binding. Written on SIWE sign-in when the session
// carries a pendingReferrer captured from a `?ref=0x…` landing URL.
// One-time lock: `referred` is unique, so the first referrer wins
// forever and later visits with a different ref are ignored.
model Referral {
  id            String   @id @default(cuid())
  referrer      String   // lowercased 0x… wallet
  referred      String   @unique  // lowercased 0x… wallet
  createdAt     DateTime @default(now())

  @@index([referrer])
}

// Prototype "Squid Dive" gambling mode. Commit-reveal is fully off-chain
// for now: the server generates a secret seed, publishes keccak256(seed)
// when the round opens, and reveals the raw seed on settle. The outcome
// index is keccak256(seed || userSalt) mod datasetSize. Everything needed
// to verify is stored on the row so /api/dive/verify can prove fairness.
model DiveRound {
  id            String    @id @default(cuid())
  address       String    // lowercased 0x… wallet of the player
  tier          String    // "low" | "mid" | "high"
  betWei        String    // wei as string; charged from DiveBalance on open
  userSalt      String    // 0x… hex from the client, bound before reveal
  seedHash      String    // keccak256 of the server seed, committed on open
  seed          String?   // raw server seed, null until settle
  outcomeIndex  Int?      // keccak256(seed || salt) mod N, null until settle
  distance      Int?      // chosen from tier dataset[outcomeIndex]
  payoutWei     String?   // wei as string, null until settle
  createdAt     DateTime  @default(now())
  settledAt     DateTime?

  @@index([address, createdAt])
}

// Mock wei balance for the prototype. Funded via /api/dive/faucet during
// testing; no real ETH changes hands. When we wire the on-chain contract,
// this table goes away and the contract's internal ledger becomes truth.
model DiveBalance {
  address       String   @id  // lowercased 0x…
  wei           String   @default("0") // wei as string
  updatedAt     DateTime @updatedAt
}
