# Railway injects DATABASE_URL when you attach a Postgres plugin.
DATABASE_URL="postgresql://user:password@localhost:5432/inksquid"

# Any 32+ char random string. Used to sign the iron-session cookie.
# Generate: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Required by RainbowKit for WalletConnect-based wallets.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# "mainnet" or "sepolia". Which Ink network the app targets.
NEXT_PUBLIC_INK_NETWORK="sepolia"

# Gate for POST /api/admin/settle and /api/admin/settle/record. Any 32+ char
# random string. Used by scripts/settle-week.ts in the x-admin-secret header.
ADMIN_SECRET="change-me-to-another-long-random-string"

# SETTLER_PRIVATE_KEY is intentionally NOT read by the web server. The key
# lives only on the admin's machine and is consumed by scripts/settle-week.ts
# when broadcasting settleWeek(). See CLAUDE.md "Settlement (end-of-week)".
