# Railway injects DATABASE_URL when you attach a Postgres plugin.
DATABASE_URL="postgresql://user:password@localhost:5432/inksquid"

# Any 32+ char random string. Used to sign the iron-session cookie.
# Generate: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Required by RainbowKit for WalletConnect-based wallets.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# "mainnet" or "sepolia". Which Ink network the app targets.
NEXT_PUBLIC_INK_NETWORK="sepolia"

# Gate for POST /api/admin/settle and /api/admin/settle/record. Any 32+ char
# random string. Used by scripts/settle-week.ts in the x-admin-secret header.
ADMIN_SECRET="change-me-to-another-long-random-string"

# SETTLER_PRIVATE_KEY is intentionally NOT read by the web server. The key
# lives only on the admin's machine and is consumed by scripts/settle-week.ts
# when broadcasting settleWeek(). See CLAUDE.md "Settlement (end-of-week)".

# ---------------------------------------------------------------------
# InkSquidGame (unified chests + cannon, Ownable2Step) per-chain addresses.
# Leave blank for chains where the contract isn't deployed yet — the UI
# flags that chain as "no game contract" instead of throwing.
# ---------------------------------------------------------------------
NEXT_PUBLIC_GAME_ADDRESS=""              # Ink Sepolia (chainId 763373)
NEXT_PUBLIC_GAME_ADDRESS_INK=""          # Ink mainnet (chainId 57073)
NEXT_PUBLIC_GAME_ADDRESS_MINATO=""       # Soneium Minato (chainId 1946)
NEXT_PUBLIC_GAME_ADDRESS_SONEIUM=""      # Soneium mainnet (chainId 1868)

# Resolver key. One SIGNER_PRIVATE_KEY works for all chains (legacy
# setup). For mainnet, prefer per-chain keys so a compromise of one
# chain's resolver doesn't expose the other:
SIGNER_PRIVATE_KEY=""                    # fallback used when per-chain key unset
# SIGNER_PRIVATE_KEY_INK=""              # Ink mainnet only (recommended)
# SIGNER_PRIVATE_KEY_SONEIUM=""          # Soneium mainnet only (recommended)
# SIGNER_PRIVATE_KEY_INK_SEPOLIA=""      # Ink Sepolia
# SIGNER_PRIVATE_KEY_MINATO=""           # Soneium Minato

# Campaign endpoint: lower bound for log scan per chain. Without this
# /api/campaign/progress will sweep from block 0 and rate-limit against
# public RPCs. Set to a block near (or just before) the first game
# deploy on that chain.
# CAMPAIGN_FROM_BLOCK_57073=""           # Ink mainnet
# CAMPAIGN_FROM_BLOCK_1868=""            # Soneium mainnet
# CAMPAIGN_FROM_BLOCK_763373=""          # Ink Sepolia
# CAMPAIGN_FROM_BLOCK_1946=""            # Soneium Minato
